# Model Policy Defaults
AI_MODEL_REWRITE=configure-me
AI_MODEL_CONTINUE=configure-me
AI_MODEL_SUMMARIZE=configure-me
AI_MODEL_CRITIQUE=configure-me
AI_MODEL_FALLBACK=configure-me
