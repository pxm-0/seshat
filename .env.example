# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3000
SESSION_SECRET=change-me

# Database
POSTGRES_USER=writer
POSTGRES_PASSWORD=writer_dev_password
POSTGRES_DB=seshat
DATABASE_URL=postgresql://writer:writer_dev_password@localhost:5432/seshat

# Redis
REDIS_URL=redis://localhost:6379

# AI Provider Gateways
AI_PROVIDER=openrouter
AI_PROVIDER_REWRITE=openrouter
AI_PROVIDER_CONTINUE=openrouter
AI_PROVIDER_SUMMARIZE=openrouter
AI_PROVIDER_CRITIQUE=openrouter
OPENROUTER_API_KEY=replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_BASE_URL=https://api.anthropic.com
BEDROCK_REGION=us-east-1

# AI Cost Controls
AI_DAILY_BUDGET_USD=2.00
AI_MONTHLY_BUDGET_USD=25.00
AI_CONFIRM_ABOVE_USD=0.05

# Model Policy Defaults
AI_MODEL_REWRITE=configure-me
AI_MODEL_CONTINUE=configure-me
AI_MODEL_SUMMARIZE=configure-me
AI_MODEL_CRITIQUE=configure-me
AI_MODEL_FALLBACK=configure-me
